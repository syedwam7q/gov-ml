# --- Aegis dashboard local development env -------------------------------
# Copy to `.env.local` and fill in the values. None of this leaves the
# repo — `.env*` is in `.gitignore`.

# --- Clerk (auth) ---------------------------------------------------------
# Both keys must be present for auth to engage. If either is unset, the
# middleware falls back to a no-op so the dashboard boots without auth.
# Get keys from https://dashboard.clerk.com → Aegis project → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Routes Clerk redirects to. Keep these in sync with the auth pages we
# implement in Phase 4d.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/fleet
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# --- Aegis control plane --------------------------------------------------
# Where the FastAPI control plane is reachable from the browser. Defaults
# to the Vercel preview URL in production.
NEXT_PUBLIC_CONTROL_PLANE_URL=http://localhost:8000

# --- Operational toggles --------------------------------------------------
# `true` blocks every automated remediation and renders the red banner.
# Admins flip this from /settings; this env is a hard override.
EMERGENCY_STOP=false
