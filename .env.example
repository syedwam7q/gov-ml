# ============================================================================
# Aegis · environment variables · documented in setup.md
# Copy to `.env` and fill in your local values. Never commit `.env`.
# ============================================================================

# --- Auth (Clerk) -----------------------------------------------------------
# Get from https://dashboard.clerk.com (free tier · 10K MAU)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# --- Database (Neon Postgres) ------------------------------------------------
# Get from https://console.neon.tech (free tier · 0.5 GB · 191.9 compute-hr/mo)
# The `postgresql://` scheme is auto-rewritten to `postgresql+asyncpg://`
# at runtime; `?sslmode=require&channel_binding=require` query params are
# stripped (asyncpg uses ssl='require' via connect args, not URL params).
# Just paste what Neon gives you.
DATABASE_URL=postgresql://user:pass@ep-cool-thing.region.aws.neon.tech/aegis?sslmode=require
DATABASE_URL_DIRECT=postgresql://user:pass@ep-cool-thing.region.aws.neon.tech/aegis?sslmode=require

# --- Hot metrics (Tinybird) -------------------------------------------------
# Get from https://app.tinybird.co (Build plan · free).
# IMPORTANT: Tinybird tokens are region-specific. Decode your token's payload
# (base64 the middle JWT segment) to find "host": "us-east-aws" /
# "ap-east-aws" / "eu-west-aws" / etc. Set TINYBIRD_HOST accordingly:
#   us-east   → https://api.tinybird.co  (default)
#   ap-east   → https://api.ap-east.aws.tinybird.co
#   eu-west   → https://api.eu-west.aws.tinybird.co
# Wrong host → 401 from Tinybird → control-plane returns 503 with detail.
TINYBIRD_TOKEN=p.eyJ...
TINYBIRD_HOST=https://api.tinybird.co

# --- Object storage (Vercel Blob) -------------------------------------------
# Get from https://vercel.com/dashboard/stores (Hobby · 1 GB)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# --- Heavy ML inference (Hugging Face Spaces) -------------------------------
# Get from https://huggingface.co/settings/tokens (free)
HF_TOKEN=hf_...
HF_TOXICITY_SPACE_URL=https://syedwam7q-aegis-toxicity.hf.space
HF_DETECT_TEXT_SPACE_URL=https://syedwam7q-aegis-detect-text.hf.space

# --- LLM (Groq, free dev tier) ----------------------------------------------
# Get from https://console.groq.com/keys.
# Free tier: 100K tokens/day per organization. Heavy testing burns through it
# fast; upgrade to dev tier ($1 minimum) at /settings/billing for 10× headroom.
# `pnpm start:all` watches .env so a key swap auto-reloads in ~1 second.
GROQ_API_KEY=gsk_...
GROQ_MODEL_QUALITY=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# --- Assistant tunables (services/assistant) --------------------------------
# Hard cap on tool-call loop iterations per chat turn (1-20).
CHAT_MAX_ITERATIONS=6
# Per-request HTTP timeout for tool dispatchers (seconds, 1-60).
TOOL_REQUEST_TIMEOUT_S=10.0

# --- Optional Redis for Phase 7 bandit persistence --------------------------
# When set, action-selector persists CB-Knapsack posterior to
# action_selector:bandit:<model_id>. Falls back to in-memory when unset.
# REDIS_URL=redis://localhost:6379

# --- Local dev — service URLs (override only if non-default ports) ----------
# Where the dashboard's dev rewrites + the assistant's tool dispatchers
# expect each service. Defaults match `pnpm start:all`.
# AEGIS_CONTROL_PLANE_DEV_URL=http://127.0.0.1:8000
# AEGIS_ASSISTANT_DEV_URL=http://127.0.0.1:8005
# CONTROL_PLANE_URL=http://127.0.0.1:8000
# CAUSAL_ATTRIB_URL=http://127.0.0.1:8003
# ACTION_SELECTOR_URL=http://127.0.0.1:8004

# --- Inter-service auth (HMAC, generate locally) ----------------------------
# `openssl rand -hex 32`
INTER_SERVICE_HMAC_SECRET=

# --- Audit-log signing (HMAC, generate locally; rotates yearly) -------------
# `openssl rand -hex 64`
AUDIT_LOG_HMAC_SECRET=

# --- Operational toggles ----------------------------------------------------
EMERGENCY_STOP=false
NODE_ENV=development
